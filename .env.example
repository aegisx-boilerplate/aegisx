# Example environment variables for development
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/aegisx

# Redis Configuration  
REDIS_URL=redis://localhost:6379

# RabbitMQ Configuration
RABBITMQ_URL=amqp://admin:password@localhost:5672

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your_jwt_secret_here_change_in_production

# For Docker development - uncomment and use service names
# DATABASE_URL=postgres://user:password@db:5432/aegisx
# REDIS_URL=redis://redis:6379
# RABBITMQ_URL=amqp://admin:password@rabbitmq:5672
