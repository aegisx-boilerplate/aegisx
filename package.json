{
  "name": "aegisx-boilerplate",
  "version": "1.1.0",
  "description": "Fastify + TypeScript + Knex + Redis + TypeBox API Boilerplate",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "swc src -d dist --copy-files",
    "start": "node dist/src/server.js",
    "start:prod": "npm run build && npm run start",
    "knex:migrate": "knex migrate:latest --knexfile dist/src/db/knexfile.js",
    "knex:seed": "knex seed:run --knexfile dist/src/db/knexfile.js",
    "setup:eventbus": "ts-node scripts/setup-event-bus.ts",
    "setup:local": "./scripts/start-local-services.sh",
    "stop:local": "./scripts/stop-local-services.sh",
    "generate:module": "node scripts/generate-module.js",
    "test:events": "echo '🚀 Testing Event System...' && curl -s http://localhost:3000/events/status | jq . && echo '✅ Event system is running!'",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "commit": "cz",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "check": "npm run lint && npm run type-check && npm run build",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.0.2",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@types/axios": "^0.9.36",
    "amqplib": "^0.10.8",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "redis": "^4.6.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.3",
    "@semantic-release/npm": "^12.0.1",
    "@swc/cli": "^0.7.7",
    "@swc/core": "^1.11.29",
    "@types/amqplib": "^0.10.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.8.1",
    "npm": ">=9.0.0"
  },
  "type": "commonjs",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true
    },
    "target": "es2020"
  },
  "sourceMaps": true,
  "outDir": "dist",
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
