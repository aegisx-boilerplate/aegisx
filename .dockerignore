# ==============================================================================
# .dockerignore for AegisX API Boilerplate
# Excludes unnecessary files from Docker build context for faster builds
# ==============================================================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.npm
.yarn-integrity

# Build outputs
dist/
*.tgz
*.tar.gz

# Environment files (will be injected at runtime via docker-compose)
.env.local
.env.development
.env.test
# Keep .env for Docker builds

# Logs
logs/
*.log

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
.pnp
.pnp.js

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Git
.git/
.gitignore
.gitattributes

# GitHub
.github/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Development and CI/CD files
docker-compose.yml
docker-compose.*.yml
Dockerfile*
.dockerignore
.editorconfig
.prettierrc*
.eslintrc*
tsconfig.json
.commitlintrc*
.husky/

# Documentation
README.md
CHANGELOG.md
LICENSE
docs/

# Scripts (these might contain dev-only scripts)
scripts/

# Testing
test/
tests/
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# Examples
examples/
